# ==========================================
# UniAI Kernel 环境变量示例 (.env.example)
# ==========================================

# --- 1. 核心环境 ---
ENVIRONMENT=development
DOMAIN=localhost
PORT=8000
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173

# --- 2. 数据库配置 (PostgreSQL + pgvector) ---
# [注意] 若使用 docker-compose 启动，POSTGRES_SERVER 请填写 'postgres'
# [注意] 若本地原生运行且使用 docker-compose.local.yml 后台，POSTGRES_PORT 请填写 '5433'
ENABLE_DATABASE=True
ENABLE_MEMORY=True
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_db
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 3) 安全基线 ---
# 已废弃：/dashboard 不再使用共享口令门禁，统一使用 JWT 登录体系
DASHBOARD_PASSWORD=deprecated-not-used
SECRET_KEY=change-this-jwt-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 必须是 Fernet 可用 key（32-byte urlsafe base64）
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# 鉴权回退与安全控制（生产建议保持默认）
ALLOW_ANONYMOUS_ADMIN_FALLBACK=False
ENFORCE_PRODUCTION_SECURITY=True
ENABLE_DYNAMIC_CLI_TOOLS=False

# --- 4) 默认用户初始化（仅开发演示） ---
DEFAULT_USER_ID=admin
# 默认建议留空；如需演示可显式设置
# DEFAULT_USER_API_KEY=

# --- 5) 默认模型（LiteLLM 兼容） ---
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_API_KEY=sk-xxxx
DEFAULT_LLM_API_BASE=

# Embedding (嵌入模型)
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_EMBEDDING_API_KEY=sk-xxxx
DEFAULT_EMBEDDING_API_BASE=

# Rerank (重排序)
DEFAULT_RERANK_PROVIDER=
DEFAULT_RERANK_MODEL=
DEFAULT_RERANK_API_KEY=

# TTS/STT (语音合成与识别)
DEFAULT_TTS_PROVIDER=
DEFAULT_TTS_MODEL=
DEFAULT_TTS_API_KEY=
DEFAULT_STT_PROVIDER=
DEFAULT_STT_MODEL=
DEFAULT_STT_API_KEY=

# --- 6) Agent 与记忆 ---
MAX_AGENT_ITERATIONS=25
MEMORY_EXTRACTION_ENABLED=True
# 触发提取的消息条数阈值
MEMORY_AUTO_EXTRACT_THRESHOLD=5
# 记忆合并相似度阈值 (0.0-1.0)
MEMORY_CONSOLIDATION_THRESHOLD=0.8
# 触发会话压缩的消息条数
SESSION_COMPRESSION_THRESHOLD=20

# --- 7) 联网检索（成熟检索链路） ---
# auto 会优先使用已配置 key 的后端，再回退 duckduckgo
WEB_SEARCH_PROVIDER=auto
WEB_SEARCH_TIMEOUT_SECONDS=15.0
TAVILY_API_KEY=
SERPER_API_KEY=

WEB_SEARCH_ENABLE_PAGE_FETCH=True
WEB_SEARCH_MAX_CANDIDATES=12
WEB_SEARCH_MAX_PAGE_FETCH=6
WEB_SEARCH_PAGE_CHAR_LIMIT=3000
WEB_SEARCH_CACHE_TTL_SECONDS=300
WEB_SEARCH_BLOCKED_DOMAINS=localhost,127.0.0.1,0.0.0.0

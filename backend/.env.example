# ==========================================
# UniAI Kernel 环境变量示例 (.env.example)
# ==========================================

# --- 1. 核心环境 ---
ENVIRONMENT=development
DOMAIN=localhost
PORT=8000
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173

# --- 2. 数据库配置 (PostgreSQL + pgvector) ---
# [注意] 若使用 docker-compose 启动，POSTGRES_SERVER 请填写 'postgres'
# [注意] 若本地原生运行且使用 docker-compose.local.yml 后台，POSTGRES_PORT 请填写 '5433'
ENABLE_DATABASE=True
ENABLE_MEMORY=True
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_db

# --- 3. 缓存配置 (Redis) ---
# [注意] 若使用 docker-compose 启动，REDIS_HOST 请填写 'redis'
# [注意] 若本地原生运行且使用 docker-compose.local.yml 后台，REDIS_PORT 请填写 '6380'
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 4. 安全配置 ---
# 控制台访问令牌 (Dashboard 认证)
DASHBOARD_PASSWORD=uniai-admin-2026
# JWT 签名密钥（生产环境必须修改为高强度随机值）
SECRET_KEY=change-this-in-production
# JWT 算法
ALGORITHM=HS256
# JWT 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# API Key 加密密钥 (必须是 32 位 URL 安全的 Base64 字符串)
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=zO8_H6G_6-uG9JpX1Z2I3Q4W5E6R7T8Y9U0I1O2P3A4=

# --- 5. 自动初始化 (开发演示专用) ---
DEFAULT_USER_ID=admin
# 默认不注入 Seed Key；仅在你需要演示时显式填写，例如 123456
# DEFAULT_USER_API_KEY=

# --- 6. 默认模型配置 (LiteLLM 兼容) ---
# LLM (聊天模型)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_API_KEY=sk-xxxx
DEFAULT_LLM_API_BASE=

# Embedding (嵌入模型)
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_EMBEDDING_API_KEY=sk-xxxx
DEFAULT_EMBEDDING_API_BASE=

# Rerank (重排序)
DEFAULT_RERANK_PROVIDER=
DEFAULT_RERANK_MODEL=
DEFAULT_RERANK_API_KEY=

# TTS/STT (语音合成与识别)
DEFAULT_TTS_PROVIDER=openai
DEFAULT_TTS_MODEL=tts-1
DEFAULT_TTS_API_KEY=sk-xxxx
DEFAULT_STT_PROVIDER=openai
DEFAULT_STT_MODEL=whisper-1
DEFAULT_STT_API_KEY=sk-xxxx

# --- 7. 智能引擎与记忆管理 ---
# 是否启用自动记忆提取
MEMORY_EXTRACTION_ENABLED=True
# 触发提取的消息条数阈值
MEMORY_AUTO_EXTRACT_THRESHOLD=5
# 记忆合并相似度阈值 (0.0-1.0)
MEMORY_CONSOLIDATION_THRESHOLD=0.8
# 触发会话压缩的消息条数
SESSION_COMPRESSION_THRESHOLD=20
# Agent 最大迭代次数
MAX_AGENT_ITERATIONS=25
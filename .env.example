# --- General ---
ENVIRONMENT=development
DOMAIN=localhost
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173

# --- Database ---
POSTGRES_USER=root
POSTGRES_PASSWORD=your_password_here
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Security ---
ENCRYPTION_KEY=

# --- Memory Management ---
MEMORY_EXTRACTION_ENABLED=true
MEMORY_CONSOLIDATION_THRESHOLD=0.8
SESSION_COMPRESSION_THRESHOLD=20

# =========================================================================
# 快速配置：默认模型（推荐）
# =========================================================================
# 配置后启动即可使用，无需调用 API
# 优先级：用户 API 配置 > 环境变量 > 系统免费模板
#
# --- LLM（对话模型）---
# 选项 1: DeepSeek（免费，需注册：platform.deepseek.com）
DEFAULT_LLM_PROVIDER=DeepSeek
DEFAULT_LLM_MODEL=deepseek-chat
DEFAULT_LLM_API_KEY=
#
# 选项 2: OpenAI
# DEFAULT_LLM_PROVIDER=OpenAI
# DEFAULT_LLM_MODEL=gpt-4
# DEFAULT_LLM_API_KEY=sk-proj-xxx
#
# 选项 3: Groq（免费，超快，console.groq.com）
# DEFAULT_LLM_PROVIDER=Groq
# DEFAULT_LLM_MODEL=llama-3.1-70b-versatile
# DEFAULT_LLM_API_KEY=gsk_xxx
#
# 选项 4: 智谱 GLM（免费额度，open.bigmodel.cn）
# DEFAULT_LLM_PROVIDER=智谱AI
# DEFAULT_LLM_MODEL=glm-4
# DEFAULT_LLM_API_KEY=

# --- Embedding（向量模型）---
# DEFAULT_EMBEDDING_PROVIDER=OpenAI
# DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
# DEFAULT_EMBEDDING_API_KEY=sk-xxx

# --- Rerank（重排序模型，可选）---
# DEFAULT_RERANK_PROVIDER=
# DEFAULT_RERANK_MODEL=
# DEFAULT_RERANK_API_KEY=

